---
interface Props { height?: string; }
const { height = '480px' } = Astro.props;
---
<div class="viewer3d" style={`height:${height}`}>
  <canvas id="v3d-canvas"></canvas>
  <span class="v3d-hint" id="v3d-hint">✋ Drag to rotate &middot; scroll to zoom</span>
  <span class="v3d-badge">3D demo model</span>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  const canvas = document.getElementById('v3d-canvas');
  const container = canvas?.parentElement;
  if (canvas && container) {
    try {
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.outputColorSpace = THREE.SRGBColorSpace;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.12;

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0xf6f8fa);

      const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
      camera.position.set(0, 3.6, 6.2);

      scene.add(new THREE.HemisphereLight(0xffffff, 0xb8c4d2, 0.95));
      const key = new THREE.DirectionalLight(0xffffff, 1.05);
      key.position.set(5, 9, 6);
      scene.add(key);
      const fill = new THREE.DirectionalLight(0xdce6f5, 0.45);
      fill.position.set(-6, 2, -5);
      scene.add(fill);
      const rim = new THREE.DirectionalLight(0xffffff, 0.35);
      rim.position.set(0, -4, -6);
      scene.add(rim);

      // --- Stylised, unbranded outsole (procedural) ---
      const wHeel = 0.62, wToe = 0.92;
      const shape = new THREE.Shape();
      shape.moveTo(-wHeel, 1.5);
      shape.quadraticCurveTo(0, 1.98, wHeel, 1.5);
      shape.quadraticCurveTo(1.08, 0.2, wToe, -1.5);
      shape.quadraticCurveTo(0, -2.05, -wToe, -1.5);
      shape.quadraticCurveTo(-1.08, 0.2, -wHeel, 1.5);
      const geo = new THREE.ExtrudeGeometry(shape, {
        depth: 0.55, bevelEnabled: true, bevelThickness: 0.16,
        bevelSize: 0.16, bevelSegments: 5, curveSegments: 40,
      });
      geo.center();
      const bodyMat = new THREE.MeshStandardMaterial({ color: 0x17335f, roughness: 0.42, metalness: 0.1 });
      const sole = new THREE.Mesh(geo, bodyMat);

      const part = new THREE.Group();
      part.add(sole);

      const studMat = new THREE.MeshStandardMaterial({ color: 0x0e2347, roughness: 0.55, metalness: 0.05 });
      const studGeo = new THREE.CylinderGeometry(0.17, 0.19, 0.16, 24);
      const studs = [[-0.4,1.05],[0.4,1.05],[-0.58,0.25],[0.58,0.25],[-0.55,-0.55],[0.55,-0.55],[-0.4,-1.3],[0.4,-1.3],[0,-1.35]];
      for (const [x, y] of studs) {
        const s = new THREE.Mesh(studGeo, studMat);
        s.rotation.x = Math.PI / 2;
        s.position.set(x, y, -(0.275 + 0.07));
        part.add(s);
      }
      part.rotation.x = -Math.PI / 2 + 0.32;
      scene.add(part);

      const controls = new OrbitControls(camera, renderer.domElement);
      controls.target.set(0, 0, 0);
      controls.enableDamping = true;
      controls.dampingFactor = 0.08;
      controls.enablePan = false;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.7;
      controls.minDistance = 4;
      controls.maxDistance = 11;
      controls.minPolarAngle = 0.4;
      controls.maxPolarAngle = Math.PI - 0.4;

      const hint = document.getElementById('v3d-hint');
      controls.addEventListener('start', () => {
        controls.autoRotate = false;
        if (hint) hint.style.opacity = '0';
      });

      function resize() {
        const w = container.clientWidth, h = container.clientHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      new ResizeObserver(resize).observe(container);
      resize();

      (function loop() {
        requestAnimationFrame(loop);
        controls.update();
        renderer.render(scene, camera);
      })();
    } catch (e) {
      container.innerHTML = '<div style="display:grid;place-items:center;height:100%;color:#5b6b7b;font-size:14px">3D preview not supported on this device.</div>';
    }
  }
</script>

<style>
  .viewer3d { position: relative; width: 100%; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; background: #f6f8fa; box-shadow: var(--shadow-sm); }
  .viewer3d canvas { display: block; width: 100%; height: 100%; cursor: grab; }
  .viewer3d canvas:active { cursor: grabbing; }
  .v3d-hint { position: absolute; left: 50%; bottom: 16px; transform: translateX(-50%); background: rgba(8,24,47,.82); color: #fff; font-family: 'Archivo', sans-serif; font-weight: 600; font-size: 12px; padding: 7px 15px; border-radius: 20px; transition: opacity .45s ease; pointer-events: none; white-space: nowrap; }
  .v3d-badge { position: absolute; top: 12px; right: 12px; background: #fff; border: 1px solid var(--line); color: var(--steel); font-family: 'Archivo', sans-serif; font-weight: 700; font-size: 11px; padding: 4px 10px; border-radius: 20px; }
</style>
