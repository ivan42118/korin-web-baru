---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const cats = [
  { name: 'Outsoles', desc: 'Traction systems molded in TPR, TPU and rubber compounds — any pattern, any durometer.', tag: 'Any tread pattern', accent: '#0E2347', rev: false },
  { name: 'Heel Counters', desc: 'Stability shells engineered from soft to rigid, in any geometry and thickness.', tag: 'Any geometry', accent: '#D7232E', rev: true },
  { name: 'Quarters & Panels', desc: 'Decorated panels with transpaper, spray, gradients and special surface effects.', tag: 'Any finish', accent: '#1763C6', rev: false },
  { name: 'EVA & Midsoles', desc: 'Lightweight cushioning molded at any density, shape and color.', tag: 'Any density', accent: '#2F84F0', rev: true },
  { name: 'Heel Patches & Trims', desc: 'Logo parts, heel patches and trims, molded precisely to your spec.', tag: 'Made to spec', accent: '#0E2347', rev: false },
  { name: 'Straps & Accessories', desc: 'Eyestays, straps and functional accessories for footwear and beyond.', tag: 'Custom designs', accent: '#D7232E', rev: true },
];
const tiles = [1, 2, 3, 4, 5, 6, 7, 8];
---
<BaseLayout title="Products & Applications — PT Korin Technomic" description="Korin develops and mass-produces fully customized footwear components across every category: outsoles, heel counters, quarters, EVA midsoles, trims and accessories." active="Products">
  <PageHeader eyebrow="Products &amp; Applications" title="Any component. Any design." description="Across every category, Korin develops and mass-produces fully customized footwear components." crumbs={[{ label: 'Products' }]} />

  <!-- Statement -->
  <section class="section"><div class="wrap">
    <div class="statement reveal">
      <span class="eyebrow">Fully customized designs &amp; development</span>
      <h2>We don&rsquo;t make <span class="hl">a</span> part.<br/>We make <span class="hl">your</span> part.</h2>
      <p>From a single prototype to millions of pairs, Korin engineers and molds footwear components to your exact shape, finish, material and color — across every category below.</p>
    </div>
    <div class="bignums">
      <div class="bignum reveal"><b>1999</b><span>Molding since</span></div>
      <div class="bignum reveal"><b>2</b><span>Factories &middot; Tangerang &amp; Cirebon</span></div>
      <div class="bignum reveal"><b>9+</b><span>Engineering materials</span></div>
      <div class="bignum reveal"><b>6</b><span>Component categories</span></div>
    </div>
  </div></section>

  <!-- Category showcases -->
  {cats.map((c, ci) => (
    <section class:list={['cat-band', { alt: ci % 2 === 1 }]}>
      <div class="wrap">
        <div class="cat-head reveal">
          <div class="cat-accent" style={`background:${c.accent}`}></div>
          <h3>{c.name}</h3>
          <div class="row2">
            <p class="cat-desc">{c.desc}</p>
            <span class="cat-tag">{c.tag}</span>
          </div>
        </div>
      </div>
      <div class="marquee reveal">
        <div class:list={['marquee-track', { rev: c.rev }]}>
          {[0, 1].map(() => tiles.map((i) => (
            <div class="vtile" style={`border-top:4px solid ${c.accent}`}>
              <div class="glow"></div><div class="lines"></div>
              <span class="idx">{String(i).padStart(2, '0')}</span>
              <span class="vtag">Photo</span>
              <span class="vlabel">Design {String(i).padStart(2, '0')}</span>
            </div>
          )))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="section final"><div class="wrap">
    <h2>Have a design in mind?</h2>
    <p>Send us your drawing, sample or idea — our development team will turn it into a production-ready component.</p>
    <div class="cta"><a class="btn btn-red" href="/contact">Request a Quote &rarr;</a><a class="btn btn-ghost" href="/capabilities">See our capabilities</a></div>
  </div></section>

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</BaseLayout>
